        "6_LINES_SHALLOW": (typeof ORCA_DATA !== 'undefined') ? ORCA_DATA["6_LINES_SHALLOW"] : null,
        "6_LINES_DEEP": (typeof ORCA_DATA_DEEP !== 'undefined') ? ORCA_DATA_DEEP["6_LINES_DEEP"] : null,
        "4_LINES_SHALLOW": (typeof ORCA_DATA_4L_SHALLOW !== 'undefined') ? ORCA_DATA_4L_SHALLOW["4_LINES_SHALLOW"] : null,
        "4_LINES_DEEP": (typeof ORCA_DATA_4L_DEEP !== 'undefined') ? ORCA_DATA_4L_DEEP["4_LINES_DEEP"] : null
    };

    const SPUD_DATA = {
        4: (typeof SPUD_LEG_LIMITS !== 'undefined') ? SPUD_LEG_LIMITS["SHALLOW_WATER_LE_4M"] : null,
        7: (typeof SPUD_LEG_LIMITS_INTERMEDIATE !== 'undefined') ? SPUD_LEG_LIMITS_INTERMEDIATE["INTERMEDIATE_WATER_LE_7M"] : null,
        11: (typeof SPUD_LEG_LIMITS_DEEP !== 'undefined') ? SPUD_LEG_LIMITS_DEEP["DEEP_WATER_LE_11M"] : null
    };

    let state = { mooring: '6_LINES_SHALLOW', stage: 'START', spud: 4, drag: null };

    function setState(key, val) {
        state[key] = val;
        const btnRow = (key === 'mooring') ? 0 : (key === 'stage' ? 1 : 2);
        document.querySelectorAll('.console .row')[btnRow].querySelectorAll('.btn').forEach(b => {
            const cmd = b.getAttribute('onclick');
            // Fixed literal matching for Desktop
            b.classList.toggle('active', cmd.includes(`'${val}'`) || cmd.includes(`, ${val}`) || cmd.includes(`${val},`));
        });
        update();
    }

    function getInterpolatedLimit(dataset, angle, period) {
        if (!dataset || Object.keys(dataset).length === 0) return null;
        let p = Math.round(period);
        if (p < 2) p = 2; if (p > 9) p = 9;
        const row = dataset[p];
        if (!row) return null;
        const baseIdx = Math.floor(angle / 30) % 12;
        const nextIdx = (baseIdx + 1) % 12;
        const fraction = (angle % 30) / 30;
        return row[baseIdx] + (row[nextIdx] - row[baseIdx]) * fraction;
    }

    function update() {
        const h = parseInt(document.getElementById('in-h').value) || 0;
        const wD = parseInt(document.getElementById('w-dir').value) || 0, sD = parseInt(document.getElementById('s-dir').value) || 0;
        const wHs = parseFloat(document.getElementById('w-hs').value) || 0, wTp = parseFloat(document.getElementById('w-per').value) || 0;
        const sHs = parseFloat(document.getElementById('s-hs').value) || 0, sTs = parseFloat(document.getElementById('s-per').value) || 0;

        // Visuals - Fixed backticks
        document.getElementById('v-group').style.transform = `rotate(${h}deg)`;
        document.getElementById('tr-h').style.transform = `rotate(${h}deg)`;
        document.getElementById('tr-w').style.transform = `rotate(${wD}deg)`;
        document.getElementById('tr-s').style.transform = `rotate(${sD}deg)`;
        document.getElementById('v-hdg').innerText = h.toString().padStart(3, '0') + "°";

        let stern = (h + 180) % 360;
        let rW = (stern - wD + 360) % 360, rS = (stern - sD + 360) % 360;
        document.getElementById('rel-w').innerText = `${rW}°`;
        document.getElementById('rel-s').innerText = `${rS}°`;

        const vSet = (ORCA_DATA_MASTER[state.mooring] || {})[state.stage];
        const sSet = SPUD_DATA[state.spud];
        
        const vLimSea = getInterpolatedLimit(vSet, rW, wTp);
        const vLimSwell = getInterpolatedLimit(vSet, rS, sTs);
        const spLimSea = getInterpolatedLimit(sSet, rW, wTp);
        const spLimSwell = getInterpolatedLimit(sSet, rS, sTs);

        processStatus('v-bar', 'MOORING', wHs, vLimSea, sHs, vLimSwell);
        processStatus('s-bar', 'SPUD OPS', wHs, spLimSea, sHs, spLimSwell);
    }

    function processStatus(id, label, seaHs, seaLim, swellHs, swellLim) {
        const el = document.getElementById(id);
        if (seaLim === null || swellLim === null) {
            el.innerText = `${label}: DATA MISSING`;
            el.className = "status-bar bg-nodata";
            return;
        }

        const seaRatio = seaHs / seaLim;
        const swellRatio = swellHs / swellLim;
        const maxRatio = Math.max(seaRatio, swellRatio);

        let status = "bg-safe";
        let text = `${label}: WITHIN LIMITS`;

        if (maxRatio > 1.0) {
            status = "bg-danger";
            const breachVal = (seaRatio > swellRatio) ? seaLim : swellLim;
            const breachType = (seaRatio > swellRatio) ? "SEA" : "SWELL";
            text = `${label}: BREACH (${breachType} LIMIT: ${breachVal.toFixed(2)}M)`;
        } else if (maxRatio > 0.9) {
            status = "bg-warning";
            text = `${label}: NEAR LIMITS`;
        }

        el.className = `status-bar ${status}`;
        el.innerText = text;
    }

    function handleMove(e) {
        if (!state.drag) return;
        const r = document.getElementById('plot').getBoundingClientRect();
        const cx = r.left + r.width/2, cy = r.top + r.height/2;
        const mx = (e.touches ? e.touches[0].clientX : e.clientX), my = (e.touches ? e.touches[0].clientY : e.clientY);
        let a = Math.round(Math.atan2(my-cy, mx-cx) * (180/Math.PI) + 90);
        if (a < 0) a += 360;
        if (state.drag === 'h') document.getElementById('in-h').value = a;
        else if (state.drag === 'w') document.getElementById('w-dir').value = a;
        else if (state.drag === 's') document.getElementById('s-dir').value = a;
        update();
    }

    const dismissKeyboard = () => { if (document.activeElement && document.activeElement.tagName === 'INPUT') document.activeElement.blur(); };

    document.querySelectorAll('input').forEach(input => {
        input.addEventListener('keypress', (e) => { if (e.key === 'Enter') input.blur(); });
        input.addEventListener('keyup', update);
        input.addEventListener('change', update);
    });

    const startDrag = (e, type) => { dismissKeyboard(); state.drag = type; };

    ['mousedown', 'touchstart'].forEach(evt => {
        document.getElementById('gr-h').addEventListener(evt, (e) => startDrag(e, 'h'));
        document.getElementById('gr-w').addEventListener(evt, (e) => startDrag(e, 'w'));
        document.getElementById('gr-s').addEventListener(evt, (e) => startDrag(e, 's'));
    });

    window.addEventListener('mousemove', handleMove);
    window.addEventListener('mouseup', () => state.drag = null);
    window.addEventListener('touchmove', (e) => { if(state.drag) e.preventDefault(); handleMove(e); }, { passive: false });
    window.addEventListener('touchend', () => state.drag = null);

    function toggleModal(s) {
        dismissKeyboard();
        if(s) {
            const vData = (ORCA_DATA_MASTER[state.mooring] || {})[state.stage];
            const sData = SPUD_DATA[state.spud];
            let h = `<h2>REFERENCE DATA</h2>`;
            h += genTableHTML(vData, `${state.mooring} (${state.stage})`);
            h += genTableHTML(sData, `SPUDS: ${state.spud}m Deployment`);
            document.getElementById('modal-content').innerHTML = h;
        }
        document.getElementById('modal').style.display = s ? 'block' : 'none';
    }

    function genTableHTML(d, t) {
        if(!d) return `<p>${t}: Data Block Missing</p>`;
        let h = `<h4>${t}</h4><table class="ref-table"><tr><th>Tp/Hdg</th>`;
        for(let deg=0; deg<360; deg+=30) h += `<th>${deg}</th>`;
        h += `</tr>`;
        for(let p=2; p<=9; p++) {
            h += `<tr><td>${p}s</td>`;
            if(d[p]) d[p].forEach(v => h += `<td>${v.toFixed(2)}</td>`);
            else for(let i=0; i<12; i++) h += `<td>-</td>`;
            h += `</tr>`;
        }
        return h + `</table>`;
    }
    
    update();
